# 資料庫配置
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/argimind

# JWT 配置（請使用 openssl rand -hex 32 產生隨機金鑰）
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 配置（JSON 陣列格式）
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Anthropic Claude API 金鑰
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# 中央氣象署開放資料平臺 API 金鑰
# 取得：https://opendata.cwa.gov.tw/
CWA_API_KEY=CWA-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Google OAuth 2.0 用戶端 ID
# 取得：https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXX.apps.googleusercontent.com

# 管理員 Email 清單（JSON 陣列格式）
ADMIN_EMAILS=["admin@example.com"]

# MCP subprocess 連線池大小（建議生產環境設為 5-10）
MCP_POOL_SIZE=10

# 開發模式：設為 true 啟用 Uvicorn 熱重載
# RELOAD=true
